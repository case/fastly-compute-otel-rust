#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")/.."

WASI_TARGET="wasm32-wasip1"
failed=0

echo "Running lints..."

# Format check
if cargo fmt --check 2>&1; then
    echo "  ✓ cargo fmt"
else
    echo "  ✗ cargo fmt"
    failed=$((failed + 1))
fi

# Clippy
if cargo clippy --target "$WASI_TARGET" -- -D warnings 2>&1; then
    echo "  ✓ cargo clippy"
else
    echo "  ✗ cargo clippy"
    failed=$((failed + 1))
fi

echo ""
if [ "$failed" -eq 0 ]; then
    echo "All checks passed."
else
    echo "$failed check(s) failed."
    exit 1
fi
